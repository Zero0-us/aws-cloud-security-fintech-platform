# ============================================================
# Terraform
# ============================================================
# State 파일 (절대 커밋 금지! 시크릿 포함)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform 작업 디렉토리
.terraform/
.terraform.lock.hcl

# 변수 파일 (개인 설정)
terraform.tfvars
terraform.tfvars.local
*.auto.tfvars
!terraform.tfvars.example

# Plan 파일
*.tfplan
*.tfplan.*

# Crash 로그
crash.log
crash.*.log

# ============================================================
# Lambda 빌드
# ============================================================
.build/
*.zip
__pycache__/
*.pyc
*.pyo

# Python 가상환경
venv/
env/
.venv/

# Lambda 외부 라이브러리 (request-parser용)
lambda/request-parser/yaml/
lambda/request-parser/_yaml/
lambda/request-parser/pyyaml-*/

# ⚠️ 최상위에 잘못 설치된 라이브러리들
/yaml/
/_yaml/
/pyyaml-*/

