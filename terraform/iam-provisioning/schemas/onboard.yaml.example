# ============================================================
# IAM 프로비저닝 - 입사자 요청 스키마
# 파일명 규칙: YYYY-MM-DD-username.yaml
# 저장 경로: s3://fin-iam-provisioning-s3/requests/onboard/
# ============================================================

# 요청 메타데이터
request_type: onboard          # 고정값 (onboard/offboard/modify)
request_id: REQ-2025-01-15-001 # 자동생성 또는 수동입력

# 사용자 정보
user:
  username: hong-gildong       # IAM 사용자명 (영문-소문자-하이픈)
  email: hong@company.com      # 임시 비밀번호 발송용
  department: 개발팀            # 소속 부서
  position: 백엔드 개발자        # 직책

# 권한 설정
access:
  target_accounts:             # 접근 허용 계정
    - dev
    - stg
  roles:                       # 부여할 IAM Role
    - Dev-Manager
  policies: []                 # 추가 인라인 정책 (선택)

# MFA 설정
mfa:
  required: true               # MFA 필수 여부
  grace_period_hours: 24       # MFA 등록 유예 시간

# 요청 정보
request:
  requester: kim-admin         # 요청자
  requester_email: kim@company.com
  requested_at: "2025-01-15T14:30:00Z"
  effective_date: "2025-01-16" # 권한 적용일
  
# 비고
notes: |
  신규 입사자 - 백엔드 개발팀
  온보딩 교육 완료 후 Prod 권한 추가 예정